---
import type { Locale } from '@lib/i18n';
import { t, htmlLang, ogLocale, otherLocale } from '@lib/i18n';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PhotoLightbox from '@components/PhotoLightbox.astro';
import '@styles/tokens.css';

interface Props {
  locale: Locale;
  title?: string | undefined;
  description?: string | undefined;
  /** sub-path (no locale prefix) of the alternate translation */
  alternatePath?: string | undefined;
  alternateMissing?: boolean;
  /** apply theme-lab inversion (used for /lab/ and /games/ pages) */
  themeLab?: boolean;
  /** when true, robots noindex (drafts, error pages) */
  noindex?: boolean;
}

const {
  locale,
  title,
  description,
  alternatePath,
  alternateMissing = false,
  themeLab = false,
  noindex = false,
} = Astro.props;

const strings = t(locale);
const fullTitle = title ? `${title} — ${strings.site.title}` : strings.site.title;
const meta = description ?? strings.site.tagline;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang={htmlLang(locale)} data-pagefind-filter={`language:${locale}`} data-pagefind-meta={`language:${locale}`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={meta} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={meta} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale(locale)} />
    <meta name="twitter:card" content="summary" />
    <link rel="alternate" type="application/rss+xml" title={`${strings.site.title} (${locale.toUpperCase()})`} href={`/${locale}/rss.xml`} />
    {alternatePath !== undefined && !alternateMissing && (
      <link rel="alternate" hreflang={htmlLang(otherLocale(locale))} href={`/${otherLocale(locale)}/${alternatePath.replace(/^\/+/, '')}/`} />
    )}
  </head>
  <body class:list={[{ 'theme-lab': themeLab }]}>
    <Header locale={locale} alternatePath={alternatePath} alternateMissing={alternateMissing} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
    <PhotoLightbox locale={locale} />
  </body>
</html>
