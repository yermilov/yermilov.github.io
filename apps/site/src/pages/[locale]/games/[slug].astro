---
import { getCollection } from 'astro:content';
import type { Locale } from '@lib/i18n';
import GameLayout from '@layouts/GameLayout.astro';

export async function getStaticPaths() {
  const all = await getCollection('games');
  const paths: Array<{ params: { locale: Locale; slug: string }; props: { entry: (typeof all)[number]; alternatePath: string | undefined; alternateMissing: boolean } }> = [];
  for (const entry of all) {
    const locale = entry.data.language;
    const counterpart = all.find(
      (other) => other.data.slug === entry.data.slug && other.data.language !== locale,
    );
    paths.push({
      params: { locale, slug: entry.data.slug },
      props: {
        entry,
        alternatePath: counterpart ? `games/${counterpart.data.slug}` : undefined,
        alternateMissing: !counterpart,
      },
    });
  }
  return paths;
}

const { entry, alternatePath, alternateMissing } = Astro.props;
const locale = Astro.params.locale as Locale;
const { Content } = await entry.render();
---

<GameLayout
  locale={locale}
  title={entry.data.title}
  description={entry.data.summary}
  controls={entry.data.controls}
  width={entry.data.width}
  height={entry.data.height}
  slug={entry.data.slug}
  publishedAt={entry.data.publishedAt}
  alternatePath={alternatePath}
  alternateMissing={alternateMissing}
>
  <div class="prose-column">
    <Content />
  </div>
</GameLayout>
