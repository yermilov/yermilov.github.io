---
import { getCollection } from 'astro:content';
import { LOCALES, t, bcp47Locale, type Locale } from '@lib/i18n';
import { getTalks } from '@lib/content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

interface GalleryItem {
  src: string;
  date: Date;
  caption?: string | undefined;
  location?: string | undefined;
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);

const standalone = await getCollection('gallery');
const talks = await getTalks();

const items: GalleryItem[] = [];
for (const entry of standalone) {
  items.push({
    src: entry.data.src,
    date: entry.data.date,
    caption: entry.data.caption,
    location: entry.data.location,
  });
}
for (const talk of talks) {
  for (const photo of talk.data.photos) {
    items.push({
      src: photo,
      date: talk.data.date,
      caption: talk.data.event,
    });
  }
}

items.sort((a, b) => b.date.getTime() - a.date.getTime());

const byYear = new Map<number, GalleryItem[]>();
for (const item of items) {
  const y = item.date.getUTCFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(item);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const monthFmt = new Intl.DateTimeFormat(bcp47Locale(locale), { month: 'short' });
function formatDate(d: Date): string {
  const day = d.getUTCDate();
  const month = monthFmt.format(d).replace(/\.$/, '').toUpperCase();
  const year = d.getUTCFullYear();
  return locale === 'ua' ? `${day} ${month} ${year}` : `${month} ${day}, ${year}`;
}
---

<BaseLayout locale={locale} title={strings.nav.gallery} alternatePath="gallery">
  <section class="page-frame index">
    <header class="prose-column">
      <p class="workbench">/ {strings.nav.gallery.toUpperCase()}</p>
      <h1>{strings.nav.gallery}</h1>
    </header>

    {items.length === 0 ? (
      <div class="prose-column">
        <p class="empty">{strings.empty.gallery}</p>
      </div>
    ) : (
      <div class="years">
        {years.map((year) => (
          <section class="year">
            <h2 class="workbench year-heading">/ {year}</h2>
            <ul class="photos gallery-grid" role="list">
              {byYear.get(year)!.map((item) => (
                <li>
                  <a href={item.src} target="_blank" rel="noopener">
                    <img src={item.src} alt="" loading="lazy" />
                    <span class="meta">
                      <span class="date">{formatDate(item.date)}</span>
                      {item.caption && <span class="caption">{item.caption}</span>}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .index {
    padding: var(--space-5) var(--space-3) var(--space-6);
  }
  .empty {
    color: var(--ink-muted);
    font-style: italic;
  }

  .years {
    margin-top: var(--space-4);
  }
  .year + .year {
    margin-top: var(--space-5);
  }
  .year-heading {
    color: var(--green-primary);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--rule);
  }

  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-3) var(--space-2);
  }
  .gallery-grid li {
    margin: 0;
  }
  .gallery-grid a {
    display: block;
    border: none;
    color: inherit;
  }
  .gallery-grid a:hover {
    background: transparent;
    color: inherit;
  }
  .gallery-grid img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--rule);
    background: var(--bg-elevated);
    transition: border-color 120ms ease;
  }
  .gallery-grid a:hover img {
    border-color: var(--orange-accent);
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 0.5rem;
  }
  .date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink);
  }
  .caption {
    font-size: 0.85rem;
    color: var(--ink-muted);
    line-height: 1.3;
  }

  @media (max-width: 540px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2);
    }
    .date {
      font-size: 0.68rem;
    }
    .caption {
      font-size: 0.78rem;
    }
  }
</style>
