---
import { LOCALES, t, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { getPostsByLocale } from '@lib/content';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);
const posts = await getPostsByLocale(locale);
---

<BaseLayout locale={locale} title={strings.nav.blog} alternatePath="blog">
  <section class="page-frame index">
    <header class="prose-column">
      <p class="workbench">/ {strings.nav.blog.toUpperCase()}</p>
      <h1>{strings.nav.blog}</h1>
    </header>
    <div class="prose-column">
      {posts.length === 0 ? (
        <p class="empty">{strings.empty.blog}</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li><PostCard post={post} locale={locale} /></li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .index {
    padding: var(--space-5) var(--space-3) var(--space-6);
  }
  .empty {
    color: var(--ink-muted);
    font-style: italic;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
