---
import { LOCALES, t, localePath, languageBadge, bcp47Locale, type Locale } from '@lib/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getTalks } from '@lib/content';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const strings = t(locale);

const today = new Date();
today.setHours(0, 0, 0, 0);
function atMidnight(d: Date): Date {
  const x = new Date(d);
  x.setHours(0, 0, 0, 0);
  return x;
}

const allTalks = await getTalks();
const upcoming = allTalks
  .filter((talk) => atMidnight(talk.data.date) >= today)
  .reverse(); // soonest first

const threeMonthsAgo = new Date(today);
threeMonthsAgo.setMonth(threeMonthsAgo.getMonth() - 3);
const recent = allTalks.filter((talk) => {
  const d = atMidnight(talk.data.date);
  return d < today && d >= threeMonthsAgo;
}); // already sorted desc by getTalks()

const monthFmt = new Intl.DateTimeFormat(bcp47Locale(locale), { month: 'short' });
const rtf = new Intl.RelativeTimeFormat(bcp47Locale(locale), { numeric: 'auto' });
const daysFromToday = (date: Date): number =>
  Math.round((atMidnight(date).getTime() - today.getTime()) / 86_400_000);

function calMonth(date: Date): string {
  return monthFmt.format(date).replace(/\.$/, '').toUpperCase();
}
---

<BaseLayout locale={locale}>
  <section class="hero">
    <div class="banner">
      <img src="/home/banner.jpg" alt="" loading="eager" />
    </div>
    <div class="page-frame hero-body">
      <div class="avatar-wrap">
        <img class="avatar" src="/home/avatar.jpg" alt={strings.site.title} loading="eager" />
      </div>
      <div class="hero-text">
        <h1 class="display">
          {strings.site.title}
          <span class="flag" aria-label="Ukraine">🇺🇦</span>
        </h1>
        <p class="role">{strings.home.role}</p>
        <p class="workbench location">▸ {strings.home.location}</p>
      </div>
      <a
        class="linkedin-stamp"
        href="https://www.linkedin.com/in/yarik-yermilov/"
        rel="me noopener"
        target="_blank"
        aria-label={strings.home.followLinkedIn}
      >
        <span class="stamp-eyebrow" aria-hidden="true">{strings.home.stampFollow}</span>
        <svg
          class="stamp-icon"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false"
        >
          <path
            fill="currentColor"
            d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
          />
        </svg>
        <span class="stamp-label" aria-hidden="true">LinkedIn</span>
        <span class="stamp-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  {upcoming.length > 0 && (
    <section class="page-frame programme">
      <p class="workbench programme-label">→ {strings.home.catchMeAt}</p>
      <ul class="programme-list" role="list">
        {upcoming.map((talk) => {
          const detailHref = localePath(locale, `talks/${talk.slug}`);
          return (
            <li class="programme-item">
              <div class="cal-tile" aria-hidden="true">
                <span class="cal-mo">{calMonth(talk.data.date)}</span>
                <span class="cal-day">{talk.data.date.getDate()}</span>
                <span class="cal-yr">{talk.data.date.getFullYear()}</span>
              </div>
              <div class="programme-content">
                <p class="workbench event">
                  ▸ {talk.data.eventUrl ? (
                    <a class="event-link" href={talk.data.eventUrl} rel="noopener">{talk.data.event}</a>
                  ) : (
                    <span>{talk.data.event}</span>
                  )}
                </p>
                <h2 class="programme-title">
                  <a href={detailHref}>{talk.data.title}</a>
                </h2>
                <p class="workbench meta">
                  <span>{rtf.format(daysFromToday(talk.data.date), 'day')}</span>
                  {talk.data.language && (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>{languageBadge(talk.data.language)}</span>
                    </>
                  )}
                </p>
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {recent.length > 0 && (
    <section class="page-frame programme programme-recent">
      <p class="workbench programme-label programme-label-recent">/ {strings.home.recent}</p>
      <ul class="programme-list" role="list">
        {recent.map((talk) => {
          const detailHref = localePath(locale, `talks/${talk.slug}`);
          return (
            <li class="programme-item">
              <div class="cal-tile cal-tile-past" aria-hidden="true">
                <span class="cal-mo">{calMonth(talk.data.date)}</span>
                <span class="cal-day">{talk.data.date.getDate()}</span>
                <span class="cal-yr">{talk.data.date.getFullYear()}</span>
              </div>
              <div class="programme-content">
                <p class="workbench event event-muted">
                  ▸ {talk.data.eventUrl ? (
                    <a class="event-link event-link-muted" href={talk.data.eventUrl} rel="noopener">{talk.data.event}</a>
                  ) : (
                    <span>{talk.data.event}</span>
                  )}
                </p>
                <h2 class="programme-title">
                  <a href={detailHref}>{talk.data.title}</a>
                </h2>
                <p class="workbench meta">
                  <span>{rtf.format(daysFromToday(talk.data.date), 'day')}</span>
                  {talk.data.language && (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>{languageBadge(talk.data.language)}</span>
                    </>
                  )}
                </p>
              </div>
            </li>
          );
        })}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
  /* HERO — LinkedIn-inspired banner + avatar overlap, but with the site's
     printed-paper typography (serif display, mono labels, sharp borders). */
  .hero {
    margin-bottom: var(--space-4);
  }
  .banner {
    width: 100%;
    aspect-ratio: 1400 / 260;
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
  }
  .banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .hero-body {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: start;
    gap: var(--space-3);
    padding-top: 0;
    padding-bottom: 0;
  }
  .avatar-wrap {
    flex: 0 0 auto;
    margin-top: -76px;
  }
  .avatar {
    width: 184px;
    height: 184px;
    border-radius: 50%;
    border: 5px solid var(--bg-paper);
    object-fit: cover;
    background: var(--bg-paper);
    display: block;
  }
  .hero-text {
    flex: 1 1 auto;
    min-width: 0;
    padding-top: var(--space-3);
  }
  .display {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 0.25rem;
    line-height: 1.1;
  }
  .flag {
    display: inline-block;
    margin-left: 0.3rem;
    font-size: 0.7em;
    vertical-align: middle;
  }
  .role {
    font-size: 1.15rem;
    color: var(--ink);
    margin: 0 0 0.3rem;
  }
  .location {
    margin: var(--space-1) 0 0;
    color: var(--green-primary);
  }

  /* LinkedIn "stamp" — postage-stamp / membership-card treatment that
     rhymes with the .cal-tile system used in the talks list below. */
  .linkedin-stamp {
    align-self: center;
    margin-top: var(--space-3);
    width: 9.5rem;
    display: grid;
    grid-template-rows: auto auto auto auto;
    justify-items: center;
    text-align: center;
    padding: 0.85rem 0.6rem 0.6rem;
    border: 2px solid var(--green-primary);
    background: var(--bg-elevated);
    color: var(--green-primary);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.05;
    position: relative;
    transition: background 140ms ease, color 140ms ease, border-color 140ms ease, transform 140ms ease;
  }
  /* Override the global a { border-bottom: ... } rule from tokens.css */
  .linkedin-stamp,
  .linkedin-stamp:hover {
    border-bottom-width: 2px;
    border-bottom-style: solid;
  }
  /* Inner perforation hint — a dashed inset line evokes a stuck-on label
     without going full kitsch. */
  .linkedin-stamp::before {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px dashed color-mix(in oklab, var(--green-primary) 35%, transparent);
    pointer-events: none;
  }
  .linkedin-stamp:hover {
    background: var(--green-primary);
    color: var(--bg-elevated);
    border-color: var(--green-primary);
    transform: translate(-1px, -1px);
  }
  .linkedin-stamp:hover::before {
    border-color: color-mix(in oklab, var(--bg-elevated) 60%, transparent);
  }
  .stamp-eyebrow {
    font-size: 0.7rem;
    color: var(--ink-muted);
    margin-bottom: 0.5rem;
  }
  .linkedin-stamp:hover .stamp-eyebrow {
    color: color-mix(in oklab, var(--bg-elevated) 75%, transparent);
  }
  .stamp-icon {
    width: 2.4rem;
    height: 2.4rem;
    margin: 0 0 0.5rem;
  }
  .stamp-label {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    text-transform: none;
    line-height: 1;
  }
  .stamp-arrow {
    margin-top: 0.45rem;
    font-size: 0.95rem;
    color: var(--orange-accent);
    transition: transform 140ms ease;
  }
  .linkedin-stamp:hover .stamp-arrow {
    color: var(--orange-bright);
    transform: translateX(3px);
  }

  @media (max-width: 600px) {
    .banner {
      /* taller on mobile so labels stay clear of the avatar overlap below */
      aspect-ratio: 1400 / 420;
    }
    .hero-body {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
    .avatar-wrap {
      margin-top: -52px;
    }
    .avatar {
      width: 132px;
      height: 132px;
      border-width: 4px;
    }
    .hero-text {
      padding-top: 0;
    }
    .linkedin-stamp {
      align-self: stretch;
      justify-self: stretch;
      width: auto;
      margin-top: var(--space-2);
      grid-template-columns: auto auto 1fr auto;
      grid-template-rows: auto;
      column-gap: 0.85rem;
      padding: 0.7rem 0.9rem;
      align-items: center;
      text-align: left;
    }
    .stamp-eyebrow {
      grid-column: 1;
      margin: 0;
    }
    .stamp-icon {
      grid-column: 2;
      width: 1.6rem;
      height: 1.6rem;
      margin: 0;
    }
    .stamp-label {
      grid-column: 3;
      justify-self: start;
      font-size: 1.1rem;
    }
    .stamp-arrow {
      grid-column: 4;
      margin: 0;
    }
  }

  /* PROGRAMME — printed-flyer rows of upcoming talks. */
  .programme {
    border-top: 2px solid var(--green-primary);
    padding: var(--space-4) var(--space-3) var(--space-5);
    margin-top: var(--space-3);
  }
  .programme-recent {
    border-top: 1px solid var(--rule);
    padding-bottom: var(--space-6);
  }
  .programme-label {
    color: var(--green-primary);
    margin: 0 0 var(--space-3);
  }
  .programme-label-recent {
    color: var(--ink-muted);
  }
  .programme-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .programme-item {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--rule);
    align-items: flex-start;
  }
  .programme-item:first-child {
    padding-top: 0;
  }
  .programme-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .cal-tile {
    flex: 0 0 auto;
    width: 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border: 1px solid var(--rule);
    background: var(--bg-elevated);
    padding: var(--space-2) 0.5rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.05;
    user-select: none;
  }
  .cal-tile-past {
    background: var(--bg-paper);
    border-style: dashed;
    color: var(--ink-muted);
  }
  .cal-mo {
    font-size: 0.78rem;
    color: var(--ink-muted);
  }
  .cal-day {
    font-family: var(--font-display);
    font-size: 2.85rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0.15rem 0;
    color: var(--ink);
  }
  .cal-tile-past .cal-day {
    color: var(--ink-muted);
  }
  .cal-yr {
    font-size: 0.7rem;
    color: var(--ink-muted);
    border-top: 1px dashed var(--rule);
    padding-top: 0.35rem;
    margin-top: 0.15rem;
    width: 100%;
  }

  .programme-content {
    flex: 1 1 auto;
    min-width: 0;
  }
  .event {
    margin: 0 0 0.4rem;
    color: var(--green-primary);
  }
  .event-muted {
    color: var(--ink-muted);
  }
  .event-link {
    border-bottom: none;
    color: var(--green-primary);
  }
  .event-link-muted {
    color: var(--ink-muted);
  }
  .event-link:hover {
    background: transparent;
    color: var(--orange-accent);
  }
  .programme-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 1.85rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }
  .programme-title a {
    border-bottom: none;
    color: inherit;
  }
  .programme-title a:hover {
    background: transparent;
    color: var(--orange-accent);
  }
  .meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 0;
  }

  @media (max-width: 540px) {
    .programme-item {
      flex-direction: column;
      gap: var(--space-2);
    }
    .cal-tile {
      width: auto;
      flex-direction: row;
      align-items: baseline;
      gap: 0.6rem;
      padding: 0.45rem 0.7rem;
    }
    .cal-day {
      font-size: 1.6rem;
      margin: 0;
    }
    .cal-yr {
      border-top: none;
      border-left: 1px dashed var(--rule);
      padding: 0 0 0 0.6rem;
      margin: 0;
      width: auto;
    }
  }
</style>
