---
import { t, type Locale } from '@lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const strings = t(locale);
---

<dialog id="photo-lightbox" class="lightbox" aria-modal="true">
  <p class="lb-counter workbench"></p>
  <button class="lb-close" type="button" aria-label={strings.labels.close}>×</button>
  <button class="lb-prev" type="button" aria-label={strings.labels.previousPhoto} hidden>‹</button>
  <button class="lb-next" type="button" aria-label={strings.labels.nextPhoto} hidden>›</button>
  <img class="lb-img" src="" alt="" />
</dialog>

<script>
  (() => {
    const dialog = document.getElementById('photo-lightbox') as HTMLDialogElement | null;
    if (!dialog) return;
    const img = dialog.querySelector<HTMLImageElement>('.lb-img');
    const counter = dialog.querySelector<HTMLElement>('.lb-counter');
    const closeBtn = dialog.querySelector<HTMLButtonElement>('.lb-close');
    const prevBtn = dialog.querySelector<HTMLButtonElement>('.lb-prev');
    const nextBtn = dialog.querySelector<HTMLButtonElement>('.lb-next');
    if (!img || !counter || !closeBtn || !prevBtn || !nextBtn) return;

    let gallery: string[] = [];
    let index = 0;
    let lastFocus: HTMLElement | null = null;

    function show(i: number) {
      if (!gallery.length || !img || !counter || !prevBtn || !nextBtn) return;
      index = (i + gallery.length) % gallery.length;
      img.src = gallery[index] ?? '';
      counter.textContent = `${index + 1} / ${gallery.length}`;
      const multiple = gallery.length > 1;
      prevBtn.hidden = !multiple;
      nextBtn.hidden = !multiple;
      // Preload adjacent images for snappier nav
      if (multiple) {
        const a = (index + 1) % gallery.length;
        const b = (index - 1 + gallery.length) % gallery.length;
        for (const j of [a, b]) {
          const url = gallery[j];
          if (url) new Image().src = url;
        }
      }
    }

    function open(g: string[], i: number) {
      if (!dialog) return;
      gallery = g;
      lastFocus = document.activeElement as HTMLElement | null;
      show(i);
      dialog.showModal();
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function close() {
      if (!dialog || !img) return;
      dialog.close();
      img.src = '';
      document.body.style.overflow = '';
      if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
    }

    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', () => show(index - 1));
    nextBtn.addEventListener('click', () => show(index + 1));

    // click on backdrop (i.e., on the dialog element itself, not the image)
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });
    // also: closing via Esc fires the 'close' event; clean body style there
    dialog.addEventListener('close', () => {
      document.body.style.overflow = '';
    });

    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') show(index - 1);
      else if (e.key === 'ArrowRight') show(index + 1);
    });

    // Hook every photo gallery on the page. Each container's <a> links form a gallery.
    document.querySelectorAll<HTMLElement>('.photos, .photo-strip').forEach((container) => {
      const links = Array.from(container.querySelectorAll<HTMLAnchorElement>('a'));
      const urls = links.map((a) => a.getAttribute('href') || '').filter(Boolean);
      if (!urls.length) return;
      links.forEach((a, i) => {
        a.addEventListener('click', (e) => {
          // Allow modifier-clicks (cmd/ctrl/shift/middle) to fall through to default behaviour
          const me = e as MouseEvent;
          if (me.metaKey || me.ctrlKey || me.shiftKey || me.button === 1) return;
          e.preventDefault();
          open(urls, i);
        });
      });
    });
  })();
</script>

<style>
  .lightbox {
    border: 0;
    padding: 0;
    background: transparent;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    color: #f4f4f4;
  }
  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox::backdrop {
    background: rgba(15, 15, 15, 0.96);
  }

  .lb-img {
    max-width: 92vw;
    max-height: 86vh;
    width: auto;
    height: auto;
    display: block;
    border: 1px solid var(--rule);
    background: #000;
  }

  .lb-counter {
    position: fixed;
    top: var(--space-2);
    left: var(--space-3);
    margin: 0;
    color: rgba(244, 244, 244, 0.7);
  }

  .lb-close,
  .lb-prev,
  .lb-next {
    position: fixed;
    background: transparent;
    border: 0;
    color: rgba(244, 244, 244, 0.85);
    font-family: var(--font-mono);
    cursor: pointer;
    padding: var(--space-2);
    line-height: 1;
    transition: color 120ms ease;
  }
  .lb-close:hover,
  .lb-prev:hover,
  .lb-next:hover {
    color: var(--orange-accent);
  }
  .lb-close:focus-visible,
  .lb-prev:focus-visible,
  .lb-next:focus-visible {
    outline: none;
    color: var(--orange-accent);
  }

  .lb-close {
    top: var(--space-2);
    right: var(--space-3);
    font-size: 2rem;
  }
  .lb-prev,
  .lb-next {
    top: 50%;
    transform: translateY(-50%);
    font-size: 3rem;
    width: 3rem;
  }
  .lb-prev {
    left: var(--space-2);
  }
  .lb-next {
    right: var(--space-2);
  }

  @media (max-width: 540px) {
    .lb-close {
      font-size: 1.6rem;
    }
    .lb-prev,
    .lb-next {
      font-size: 2.2rem;
      width: 2.2rem;
    }
  }
</style>
