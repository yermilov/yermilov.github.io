---
import type { CollectionEntry } from 'astro:content';
import { localePath, t, type Locale } from '@lib/i18n';

interface Props {
  talk: CollectionEntry<'talks'>;
  locale: Locale;
}
const { talk, locale } = Astro.props;
const strings = t(locale);
const fmt = new Intl.DateTimeFormat(locale === 'uk' ? 'uk-UA' : 'en-US', { year: 'numeric', month: 'short' });
const detailHref = localePath(locale, `talks/${talk.slug}`);
---

<article class="talk">
  <p class="workbench when">
    <time datetime={talk.data.date.toISOString()}>{fmt.format(talk.data.date)}</time>
    <span aria-hidden="true">·</span>
    {talk.data.eventUrl ? (
      <a href={talk.data.eventUrl} rel="noopener">{talk.data.event}</a>
    ) : (
      <span>{talk.data.event}</span>
    )}
    {talk.data.language && (
      <>
        <span aria-hidden="true">·</span>
        <span>{talk.data.language.toUpperCase()}</span>
      </>
    )}
  </p>
  <h3><a class="title-link" href={detailHref}>{talk.data.title}</a></h3>
  {talk.data.abstract.split(/\n\n+/).map((para) => <p class="abstract">{para}</p>)}
  {talk.data.photos.length > 0 && (
    <ul class="photos" role="list">
      {talk.data.photos.map((src) => (
        <li>
          <a href={src} target="_blank" rel="noopener">
            <img src={src} alt="" loading="lazy" />
          </a>
        </li>
      ))}
    </ul>
  )}
  <ul class="links" role="list">
    {talk.data.videoUrl && <li><a href={talk.data.videoUrl} rel="noopener">{strings.labels.video}</a></li>}
    {talk.data.slidesUrl && <li><a href={talk.data.slidesUrl} rel="noopener">{strings.labels.slides}</a></li>}
    {talk.data.repoUrl && <li><a href={talk.data.repoUrl} rel="noopener">{strings.labels.repo}</a></li>}
    <li><a class="more" href={detailHref}>→</a></li>
  </ul>
</article>

<style>
  .talk {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--rule);
  }
  .when {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 0 0 0.4rem;
  }
  h3 {
    font-size: 1.35rem;
    margin: 0 0 0.4rem;
  }
  .title-link {
    border-bottom: none;
    color: inherit;
  }
  .title-link:hover {
    background: transparent;
    color: var(--orange-accent);
  }
  .abstract {
    color: var(--ink-muted);
    margin: 0 0 var(--space-2);
  }
  .photos {
    list-style: none;
    margin: 0 0 var(--space-2);
    padding: 0;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .photos img {
    height: 120px;
    width: auto;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--rule);
    display: block;
  }
  .photos a {
    border: none;
  }
  .photos a:hover {
    background: transparent;
  }
  .photos a:hover img {
    border-color: var(--orange-accent);
  }
  .links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
</style>
