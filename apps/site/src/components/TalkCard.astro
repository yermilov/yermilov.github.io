---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '@lib/i18n';

interface Props {
  talk: CollectionEntry<'talks'>;
  locale: Locale;
}
const { talk, locale } = Astro.props;
const fmt = new Intl.DateTimeFormat(locale === 'uk' ? 'uk-UA' : 'en-US', { year: 'numeric', month: 'short' });
---

<article class="talk">
  <p class="workbench when">
    <time datetime={talk.data.date.toISOString()}>{fmt.format(talk.data.date)}</time>
    <span aria-hidden="true">·</span>
    <span>{talk.data.event}</span>
    <span aria-hidden="true">·</span>
    <span>{talk.data.language.toUpperCase()}</span>
  </p>
  <h3>{talk.data.title}</h3>
  <p class="abstract">{talk.data.abstract}</p>
  <ul class="links" role="list">
    {talk.data.videoUrl && <li><a href={talk.data.videoUrl} rel="noopener">video</a></li>}
    {talk.data.slidesUrl && <li><a href={talk.data.slidesUrl} rel="noopener">slides</a></li>}
    {talk.data.repoUrl && <li><a href={talk.data.repoUrl} rel="noopener">repo</a></li>}
  </ul>
</article>

<style>
  .talk {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--rule);
  }
  .when {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 0 0 0.4rem;
  }
  h3 {
    font-size: 1.35rem;
    margin: 0 0 0.4rem;
  }
  .abstract {
    color: var(--ink-muted);
    margin: 0 0 var(--space-2);
  }
  .links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
</style>
